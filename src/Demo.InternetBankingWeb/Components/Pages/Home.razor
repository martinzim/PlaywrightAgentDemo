@page "/"
@inject BankingPortalState PortalState
@inject NavigationManager Navigation

<PageTitle>Prihlasenie | Demo Internet Banking</PageTitle>

<section class="bank-legacy-page">
    <div class="bank-legacy-wrap">
        <div class="bank-legacy-social">
            <span class="bank-legacy-social__icon">DB</span>
            <span class="bank-legacy-social__icon">24</span>
            <span class="bank-legacy-social__icon">SE</span>
            <span class="bank-legacy-social__icon">AP</span>
            <span class="bank-legacy-social__icon">M</span>
        </div>

        <section class="bank-legacy-panel">
            <header class="bank-legacy-header">
                <div class="bank-legacy-logo" data-testid="brand-mark">
                    <span>Demo Bank</span>
                    <span class="bank-legacy-logo__mark">•</span>
                </div>
                <div class="bank-legacy-contact">
                    <div>Klientska linka: <strong>0800 310 410</strong></div>
                    <div>e-mail: <strong>support@demobank.demo</strong></div>
                </div>
            </header>

            <div class="bank-legacy-main">
                <EditForm Model="Input" OnValidSubmit="HandleLoginAsync" class="bank-legacy-login" data-testid="login-form">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <h1 data-testid="login-page-title">Internet banking</h1>

                    <div class="bank-field bank-legacy-field">
                        <label class="bank-label bank-legacy-label" for="login-username">Prihlasovacie meno / Alias / ID</label>
                        <InputText id="login-username" class="bank-input bank-legacy-input" @bind-Value="Input.Username" data-testid="login-username" />
                    </div>

                    <div class="bank-field bank-legacy-field">
                        <label class="bank-label bank-legacy-label" for="login-password">Heslo / PIN</label>
                        <InputText id="login-password" type="@(ShowPassword ? "text" : "password")" class="bank-input bank-legacy-input" @bind-Value="Input.Password" data-testid="login-password" />
                    </div>

                    <label class="bank-legacy-checkbox">
                        <InputCheckbox @bind-Value="ShowPassword" />
                        <span>Zobrazit heslo</span>
                    </label>

                    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
                    {
                        <p class="form-error" data-testid="login-error">@ErrorMessage</p>
                    }

                    <button type="submit" class="bank-legacy-submit" data-testid="login-submit">
                        Prihlasit sa
                        <span>&rsaquo;</span>
                    </button>

                    <div class="bank-legacy-help">
                        <a href="/help/security" data-testid="login-security-link">Nedari sa vam prihlasit?</a>
                    </div>
                </EditForm>

                <section class="bank-legacy-campaign">
                    <div class="bank-legacy-campaign__tab">Flexi rezerva k beznemu uctu</div>
                    <div class="bank-legacy-campaign__content">
                        <div class="bank-legacy-campaign__offer">
                            <div class="bank-legacy-rate">2,9%</div>
                            <p>rocny bonus pre aktivnych klientov banky</p>
                        </div>
                        <div class="bank-legacy-badge">NOVY ONLINE BALIK PRE DOMACNOSTI</div>
                    </div>
                    <div class="bank-legacy-slider">
                        <span></span>
                        <span class="is-active"></span>
                        <span></span>
                        <span></span>
                    </div>
                </section>
            </div>
        </section>

        <section class="bank-legacy-footer">
            <article class="bank-legacy-footer__card">
                <h2>Mobilna app Demo Pocket</h2>
                <p>Spravujte ucty, karty a notifikacie aj mimo kancelarie v prehladnej mobilnej aplikacii.</p>
            </article>
            <article class="bank-legacy-footer__card">
                <h2>Okamzite platby a sablony</h2>
                <p>Ukladajte si najcastejsich prijemcov a posielajte platby s rychlym potvrdenim priamo z dashboardu.</p>
            </article>
            <article class="bank-legacy-footer__card">
                <h2>Bezpecnost</h2>
                <p>Prakticke odporucania pre bezpecne prihlasovanie, autorizaciu platieb a ochranu pred phishingom.</p>
            </article>
        </section>

        <div class="bank-legacy-meta">
            <p data-testid="demo-credentials">Demo prihlasenie: @PortalState.DemoCredentials</p>
            <p>Demo autorizacny kod: <span data-testid="demo-auth-code">246810</span></p>
            <p>&copy; 2026 Demo Bank Digital, a.s.</p>
        </div>
    </div>
</section>

@code {
    private LoginInput Input { get; set; } = new();
    private string ErrorMessage { get; set; } = string.Empty;
    private bool ShowPassword { get; set; }

    protected override void OnInitialized()
    {
        if (PortalState.IsAuthenticated)
        {
            Navigation.NavigateTo("/dashboard", true);
        }
    }

    private Task HandleLoginAsync()
    {
        if (!PortalState.Login(Input.Username, Input.Password))
        {
            ErrorMessage = "Prihlasovacie meno alebo heslo nie je spravne.";
            return Task.CompletedTask;
        }

        ErrorMessage = string.Empty;
        Navigation.NavigateTo("/dashboard");
        return Task.CompletedTask;
    }

    private sealed class LoginInput
    {
        [Required]
        public string Username { get; set; } = "demo.klient";

        [Required]
        public string Password { get; set; } = "Demo123!";
    }
}

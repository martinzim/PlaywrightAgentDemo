@inherits LayoutComponentBase
@inject BankingPortalState PortalState
@inject NavigationManager Navigation

<div class="bank-shell @(PortalState.IsAuthenticated ? "bank-shell--authenticated" : "bank-shell--anonymous")">
    @if (PortalState.IsAuthenticated)
    {
        <aside class="bank-shell__sidebar">
            <NavMenu />
        </aside>
    }

    <main class="bank-shell__main">
        @if (PortalState.IsAuthenticated)
        {
            <header class="bank-topbar">
                <div class="bank-topbar__identity">
                    <span class="bank-topbar__label">Prima banka Slovensko, a.s.</span>
                    <strong data-testid="topbar-user">@PortalState.CurrentUser?.DisplayName</strong>
                </div>
                <div class="bank-topbar__actions">
                    <span class="bank-topbar__status">Posledne prihlasenie <strong data-testid="topbar-last-login">@PortalState.CurrentUser?.LastLoginUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</strong></span>
                    <button class="bank-button bank-button--ghost" @onclick="HandleLogout" data-testid="logout-button">Odhlasit sa</button>
                </div>
            </header>
        }

        <article class="bank-shell__content">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>

@code {
    private void HandleLogout()
    {
        PortalState.Logout();
        Navigation.NavigateTo("/", true);
    }
}

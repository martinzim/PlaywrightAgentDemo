@page
@model DemoWeb.Pages.LoginModel
@{
    ViewData["Title"] = "Client portal";
}
<section class="panel-grid">
    <div>
        <p class="section-kicker">Client portal</p>
        <h1>Sign in to review rollout status.</h1>
        <p class="supporting-copy">
            Invalid credentials show a deterministic error so negative browser checks are easy to demonstrate.
        </p>
    </div>
    <div class="form-panel">
        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert-banner" data-testid="login-error">@Model.ErrorMessage</div>
        }
        <form method="post" data-testid="login-form">
            <div class="field-grid">
                <div class="field">
                    <label asp-for="Input.Email"></label>
                    <input asp-for="Input.Email" data-testid="login-email" />
                    <span asp-validation-for="Input.Email" class="validation"></span>
                </div>
                <div class="field">
                    <label asp-for="Input.Password"></label>
                    <input asp-for="Input.Password" type="password" data-testid="login-password" />
                    <span asp-validation-for="Input.Password" class="validation"></span>
                </div>
            </div>
            <div class="form-actions">
                <button type="submit" class="primary-cta" data-testid="login-submit">Sign in</button>
            </div>
        </form>
    </div>
</section>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}